---
import SiteBackground from "../components/SiteBackground.astro";

interface Props {
  title?: string;
  description?: string;
}

const {
  title = "Viraliza — Crypto Growth Desk",
  description = "Turn your audience into exchange revenue. Pre-negotiated deals for creators, communities, and trading operations that move real volume. Zero upfront cost.",
} = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/png" href="/logo.png" />
    <meta property="og:image" content="/logo.png" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <meta name="description" content={description} />
    <title>{title}</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=IBM+Plex+Sans:ital,wght@0,400;0,500;0,600;1,400&family=Space+Grotesk:wght@400;500;600;700&display=swap"
      rel="stylesheet"
    />
  </head>
  <body>
    <svg width="0" height="0" aria-hidden="true" style="position:absolute">
      <defs>
        <linearGradient id="icon-gradient" x1="0%" y1="0%" x2="100%" y2="100%">
          <stop offset="0%" stop-color="#8B5CF6" />
          <stop offset="100%" stop-color="#22D3EE" />
        </linearGradient>
      </defs>
    </svg>
    <SiteBackground />
    <div class="page">
      <slot />
    </div>
    <script>
      import "../scripts/motion.ts";
    </script>
  </body>
</html>

<style is:global>
  @import "../styles/global.css";

  body {
    position: relative;
  }

  .page {
    position: relative;
    z-index: 1;
  }
</style>
