---
const stats = [
  { value: "$5B+", label: "Monthly volume moved", highlight: true },
  { value: "$1B+", label: "Revenue scaled", highlight: true },
  { value: "$0", label: "Upfront cost to start", highlight: false },
];
---

<div class="stats-bar" data-reveal-item>
  <p class="stats-bar__eyebrow">Proven at scale</p>
  <ul class="stats-bar__list" role="list">
    {stats.map(({ value, label, highlight }) => (
      <li class="stats-bar__item">
        <strong class:list={["stats-bar__value", highlight && "stats-bar__value--wealth"]}>{value}</strong>
        <span class="stats-bar__label">{label}</span>
      </li>
    ))}
  </ul>
</div>

<style>
  .stats-bar {
    width: 100%;
    max-width: 52rem;
    margin-top: 1rem;
    padding: 2rem 2rem 1.75rem;
    background:
      linear-gradient(165deg, rgba(228, 198, 90, 0.06) 0%, transparent 45%),
      rgba(6, 6, 10, 0.55);
    backdrop-filter: blur(24px);
    -webkit-backdrop-filter: blur(24px);
    border: 1px solid rgba(228, 198, 90, 0.12);
    border-radius: 12px;
    box-shadow: 0 24px 60px rgba(0, 0, 0, 0.35);
  }

  .stats-bar__eyebrow {
    font-family: var(--font-display);
    font-size: 0.625rem;
    font-weight: 600;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--gold);
    text-align: center;
    margin-bottom: 1.5rem;
  }

  .stats-bar__list {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.5rem;
    list-style: none;
  }

  .stats-bar__item {
    display: flex;
    flex-direction: column;
    gap: 0.375rem;
    text-align: center;
    padding-inline: 0.5rem;
  }

  .stats-bar__item:not(:last-child) {
    border-right: 1px solid rgba(255, 255, 255, 0.06);
  }

  .stats-bar__value {
    font-family: var(--font-display);
    font-size: clamp(1.75rem, 4vw, 2.5rem);
    font-weight: 600;
    letter-spacing: -0.04em;
    line-height: 1;
    color: var(--text);
  }

  .stats-bar__value--wealth {
    background: var(--gradient-wealth);
    -webkit-background-clip: text;
    background-clip: text;
    -webkit-text-fill-color: transparent;
  }

  .stats-bar__label {
    font-size: 0.6875rem;
    font-weight: 500;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    color: var(--text-dim);
    line-height: 1.4;
  }

  @media (max-width: 600px) {
    .stats-bar__list {
      grid-template-columns: 1fr;
      gap: 1.25rem;
    }

    .stats-bar__item:not(:last-child) {
      border-right: none;
      border-bottom: 1px solid rgba(255, 255, 255, 0.06);
      padding-bottom: 1.25rem;
    }
  }
</style>
