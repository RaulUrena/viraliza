---
const stats = [
  { amount: "$5B", suffix: "+", label: "Monthly volume moved", highlight: true },
  { amount: "$1B", suffix: "+", label: "In volume scaled", highlight: true },
  { amount: "$0", suffix: "", label: "Upfront cost to start", highlight: false },
];
---

<div class="stats-bar" data-reveal-item>
  <p class="stats-bar__eyebrow">Proven at scale</p>
  <ul class="stats-bar__list" role="list">
    {stats.map(({ amount, suffix, label, highlight }) => (
      <li class="stats-bar__item">
        <strong class:list={["stats-bar__value", highlight && "stats-bar__value--wealth"]}>
          <span class="stats-bar__amount">{amount}</span>
          {suffix && <span class="stats-bar__suffix">{suffix}</span>}
        </strong>
        <span class="stats-bar__label">{label}</span>
      </li>
    ))}
  </ul>
</div>

<style>
  .stats-bar {
    width: 100%;
    max-width: 52rem;
    margin-top: 1rem;
    padding: 1.5rem 1.25rem 1.25rem;
    background:
      linear-gradient(165deg, rgba(228, 198, 90, 0.06) 0%, transparent 45%),
      rgba(6, 6, 10, 0.55);
    backdrop-filter: blur(24px);
    -webkit-backdrop-filter: blur(24px);
    border: 1px solid rgba(228, 198, 90, 0.12);
    border-radius: 12px;
    box-shadow: 0 24px 60px rgba(0, 0, 0, 0.35);
  }

  .stats-bar__eyebrow {
    font-family: var(--font-display);
    font-size: 0.625rem;
    font-weight: 600;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--gold);
    text-shadow: 0 0 20px rgba(228, 198, 90, 0.28);
    text-align: center;
    margin-bottom: 1.25rem;
  }

  .stats-bar__list {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1rem;
    list-style: none;
  }

  .stats-bar__item {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    text-align: center;
    padding-inline: 0.5rem;
  }

  .stats-bar__item:not(:last-child) {
    border-right: 1px solid rgba(255, 255, 255, 0.06);
  }

  .stats-bar__value {
    display: inline-flex;
    align-items: baseline;
    justify-content: center;
    gap: 0.15em;
    font-family: var(--font-display);
    font-size: clamp(1.5rem, 4vw, 2.5rem);
    font-weight: 600;
    letter-spacing: -0.03em;
    line-height: 1.15;
    color: var(--text);
  }

  .stats-bar__amount {
    letter-spacing: -0.04em;
  }

  .stats-bar__suffix {
    font-size: 0.7em;
    font-weight: 600;
    letter-spacing: 0.04em;
    line-height: 1;
    transform: translateY(-0.06em);
  }

  .stats-bar__value--wealth .stats-bar__amount,
  .stats-bar__value--wealth .stats-bar__suffix {
    background: var(--gradient-wealth);
    -webkit-background-clip: text;
    background-clip: text;
    -webkit-text-fill-color: transparent;
  }

  .stats-bar__label {
    font-size: 0.625rem;
    font-weight: 500;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    color: var(--text-dim);
    line-height: 1.45;
  }

  @media (max-width: 600px) {
    .stats-bar {
      padding: 1.25rem 1rem;
    }

    .stats-bar__list {
      grid-template-columns: 1fr;
      gap: 1rem;
    }

    .stats-bar__item:not(:last-child) {
      border-right: none;
      border-bottom: 1px solid rgba(255, 255, 255, 0.06);
      padding-bottom: 1rem;
    }
  }
</style>
