---
---

<section class="refer" id="refer" aria-labelledby="refer-heading">
  <div class="container" data-reveal="section">
    <div class="refer__panel">
      <h2 id="refer-heading" class="refer__title" data-reveal-item>
        Refer & <span class="gradient-text">earn</span>
      </h2>
      <p class="refer__body" data-reveal-item>
        Know other creators, communities, or operations that move volume? Refer them and earn a share of the volume they bring. Aligned incentives, all the way down.
      </p>
      <div class="refer__actions" data-reveal-item>
        <a href="#contact" class="btn btn--primary">Get in touch</a>
        <a
          href="https://t.me/Viralizasupport"
          class="btn btn--secondary"
          target="_blank"
          rel="noopener noreferrer"
        >
          Telegram
        </a>
      </div>
    </div>
  </div>
</section>

<style>
  .refer {
    padding-block: 3rem;
    border-top: 1px solid var(--border);
  }

  .refer__panel {
    max-width: 40rem;
    margin-inline: auto;
    padding: 2rem 1.5rem;
    text-align: center;
    background: rgba(8, 8, 12, 0.55);
    border: 1px solid var(--border);
    border-radius: 12px;
    backdrop-filter: blur(20px);
    -webkit-backdrop-filter: blur(20px);
  }

  .refer__title {
    font-family: var(--font-display);
    font-size: clamp(1.5rem, 4vw, 2rem);
    font-weight: 600;
    letter-spacing: -0.03em;
    line-height: 1.15;
  }

  .refer__body {
    margin-top: 1rem;
    font-size: clamp(0.9375rem, 2.5vw, 1.0625rem);
    line-height: 1.7;
    color: var(--text-dim);
    max-width: 32rem;
    margin-inline: auto;
  }

  .refer__actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
    justify-content: center;
    margin-top: 1.5rem;
  }

  @media (min-width: 768px) {
    .refer {
      padding-block: 4rem;
    }

    .refer__panel {
      padding: 2.25rem 2rem;
    }
  }
</style>
