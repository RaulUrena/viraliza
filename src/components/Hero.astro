---
import StatsBar from "./StatsBar.astro";
import Logo from "./Logo.astro";

const pillars = [
  "Above-market rebates",
  "Zero upfront cost",
  "Aligned incentives",
];
---

<section class="hero" aria-labelledby="hero-heading">
  <div class="hero__glow" aria-hidden="true"></div>

  <div class="container hero__inner" data-reveal="hero">
    <div class="hero__logo" data-reveal-item>
      <Logo variant="hero" />
    </div>

    <p class="eyebrow" data-reveal-item>Crypto Growth Desk</p>

    <h1 id="hero-heading" class="hero__title" data-reveal-item>
      Turn your audience into <span class="gradient-text">exchange revenue</span>
    </h1>

    <p class="lede lede--bright hero__sub" data-reveal-item>
      Pre-negotiated exchange deals, above-market rebates, and copy-trading infrastructure — for creators, communities, and trading operations that move real volume. We only earn when you grow.
    </p>

    <ul class="hero__pillars" role="list" data-reveal-item>
      {pillars.map((item) => (
        <li class="hero__pillar">{item}</li>
      ))}
    </ul>

    <div class="hero__actions" data-reveal-item>
      <a href="#contact" class="btn btn--primary">Unlock your deal</a>
      <a href="#services" class="btn btn--secondary">See the economics</a>
    </div>

    <StatsBar />
  </div>
</section>

<style>
  .hero {
    position: relative;
    padding-block: 5rem 3.5rem;
    min-height: 100svh;
    display: flex;
    align-items: center;
    overflow: hidden;
  }

  .hero__glow {
    position: absolute;
    top: 15%;
    left: 50%;
    width: min(900px, 100vw);
    height: min(500px, 60svh);
    transform: translateX(-50%);
    background: radial-gradient(ellipse at center, rgba(228, 198, 90, 0.08) 0%, rgba(139, 92, 246, 0.12) 35%, transparent 70%);
    pointer-events: none;
  }

  .hero__inner {
    position: relative;
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    gap: 1.25rem;
    width: 100%;
  }

  .hero__logo {
    width: min(200px, 48vw);
    margin-inline: auto;
  }

  .hero__title {
    font-family: var(--font-display);
    font-size: clamp(2.25rem, 7.5vw, 5rem);
    font-weight: 600;
    line-height: 1.04;
    letter-spacing: -0.045em;
    max-width: 14ch;
    text-shadow:
      0 2px 16px rgba(0, 0, 0, 0.65),
      0 4px 48px rgba(0, 0, 0, 0.45);
  }

  .hero__sub {
    max-width: 40rem;
    text-shadow: 0 2px 20px rgba(0, 0, 0, 0.55);
  }

  .hero__pillars {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 0.5rem;
    list-style: none;
    margin-top: 0.25rem;
    max-width: 100%;
  }

  .hero__pillar {
    padding: 0.5rem 0.875rem;
    font-family: var(--font-display);
    font-size: clamp(0.625rem, 2.5vw, 0.75rem);
    font-weight: 500;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: var(--text);
    border: 1px solid rgba(255, 255, 255, 0.16);
    border-radius: 100px;
    background: rgba(255, 255, 255, 0.04);
  }

  .hero__actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
    justify-content: center;
    margin-top: 0.5rem;
    width: 100%;
    max-width: 24rem;
  }

  .hero__actions .btn {
    flex: 1 1 auto;
    min-width: min(100%, 10rem);
  }

  @media (min-width: 768px) {
    .hero {
      padding-block: 6rem 5rem;
    }

    .hero__inner {
      gap: 1.75rem;
    }

    .hero__actions {
      max-width: none;
    }

    .hero__actions .btn {
      flex: 0 1 auto;
      min-width: auto;
    }
  }
</style>
