---
import StatsBar from "./StatsBar.astro";
import Logo from "./Logo.astro";

const pillars = [
  "Above-market rebates",
  "Zero upfront cost",
  "Aligned incentives",
];
---

<section class="hero" aria-labelledby="hero-heading">
  <div class="hero__glow" aria-hidden="true"></div>

  <div class="container hero__inner" data-reveal="hero">
    <div class="hero__logo" data-reveal-item>
      <Logo variant="hero" />
    </div>

    <p class="eyebrow" data-reveal-item>Crypto Growth Desk</p>

    <h1 id="hero-heading" class="hero__title" data-reveal-item>
      Turn your audience into <span class="gradient-text">exchange revenue</span>
    </h1>

    <p class="lede lede--bright hero__sub" data-reveal-item>
      Insider deals, aggressive rebates, and copy-trading infrastructure — built to maximize what your community is worth. We only earn when you grow.
    </p>

    <ul class="hero__pillars" role="list" data-reveal-item>
      {pillars.map((item) => (
        <li class="hero__pillar">{item}</li>
      ))}
    </ul>

    <div class="hero__actions" data-reveal-item>
      <a href="#contact" class="btn btn--primary">Unlock your deal</a>
      <a href="#services" class="btn btn--secondary">See the economics</a>
    </div>

    <StatsBar />
  </div>
</section>

<style>
  .hero {
    position: relative;
    padding-block: 5rem 4rem;
    min-height: 100svh;
    display: flex;
    align-items: center;
    overflow: hidden;
  }

  .hero__glow {
    position: absolute;
    top: 15%;
    left: 50%;
    width: min(900px, 120vw);
    height: min(500px, 60vh);
    transform: translateX(-50%);
    background: radial-gradient(ellipse at center, rgba(228, 198, 90, 0.08) 0%, rgba(139, 92, 246, 0.12) 35%, transparent 70%);
    pointer-events: none;
  }

  .hero__inner {
    position: relative;
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    gap: 1.5rem;
    width: 100%;
  }

  .hero__logo {
    width: min(220px, 52vw);
    margin-inline: auto;
  }

  .hero__title {
    font-family: var(--font-display);
    font-size: clamp(2.75rem, 8vw, 5rem);
    font-weight: 600;
    line-height: 1.02;
    letter-spacing: -0.045em;
    max-width: 13ch;
    text-shadow: 0 4px 40px rgba(0, 0, 0, 0.5);
  }

  .hero__sub {
    max-width: 36rem;
    text-shadow: 0 2px 20px rgba(0, 0, 0, 0.4);
  }

  .hero__pillars {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 0.625rem;
    list-style: none;
    margin-top: 0.25rem;
  }

  .hero__pillar {
    padding: 0.5rem 1rem;
    font-family: var(--font-display);
    font-size: 0.75rem;
    font-weight: 500;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: var(--gold);
    border: 1px solid rgba(228, 198, 90, 0.25);
    border-radius: 100px;
    background: rgba(228, 198, 90, 0.06);
  }

  .hero__actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.875rem;
    justify-content: center;
    margin-top: 0.5rem;
  }

  @media (min-width: 768px) {
    .hero {
      padding-block: 6rem 5rem;
    }

    .hero__inner {
      gap: 1.75rem;
    }
  }
</style>
