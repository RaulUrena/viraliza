---
const steps = [
  "Follower → registration",
  "Registration → first deposit",
  "Deposit → first trade",
  "Trade → active, recurring user",
];
---

<section class="funnel" aria-labelledby="funnel-heading">
  <div class="container" data-reveal="section">
    <header class="section-header">
      <p class="eyebrow eyebrow--dim" data-reveal-item>The revenue funnel</p>
      <h2 id="funnel-heading" class="section-title" data-reveal-item>
        Every step optimized for <span class="gradient-text">exchange economics</span>
      </h2>
      <span class="section-line" data-reveal-item></span>
      <p class="lede funnel__intro" data-reveal-item>
        We don't just collect commissions. We help engineer the full journey — from first click to recurring volume — across deals, content, and community strategy.
      </p>
    </header>

    <ol class="funnel__steps" role="list">
      {steps.map((label) => (
        <li class="funnel__step" data-reveal-card data-interactive-card>
          <span class="funnel__label">{label}</span>
        </li>
      ))}
    </ol>
  </div>
</section>

<style>
  .funnel {
    padding-block: 4rem;
    border-top: 1px solid var(--border);
  }

  .funnel__intro {
    margin-top: 1.25rem;
  }

  .funnel__steps {
    display: grid;
    gap: 1rem;
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .funnel__step {
    position: relative;
    padding: 1.75rem 2rem;
    background:
      linear-gradient(135deg, rgba(228, 198, 90, 0.04) 0%, transparent 50%),
      rgba(8, 8, 12, 0.6);
    border: 1px solid rgba(255, 255, 255, 0.08);
    border-radius: 10px;
    backdrop-filter: blur(16px);
    overflow: hidden;
    transition: border-color 0.4s, box-shadow 0.4s, transform 0.4s;
  }

  .funnel__step::before {
    content: "";
    position: absolute;
    left: 0;
    top: 1.5rem;
    bottom: 1.5rem;
    width: 2px;
    background: var(--gradient-wealth);
    opacity: 0.5;
  }

  .funnel__step:hover {
    border-color: rgba(228, 198, 90, 0.2);
    box-shadow: 0 16px 48px rgba(0, 0, 0, 0.3);
  }

  .funnel__label {
    font-family: var(--font-display);
    font-size: clamp(1.125rem, 2.5vw, 1.5rem);
    font-weight: 500;
    letter-spacing: -0.02em;
    padding-left: 0.75rem;
  }

  @media (min-width: 768px) {
    .funnel__steps {
      grid-template-columns: repeat(2, 1fr);
      gap: 1.25rem;
    }
  }

  @media (min-width: 1024px) {
    .funnel {
      padding-block: 7rem;
    }
  }
</style>
