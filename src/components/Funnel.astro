---
const steps = [
  { from: "Follower", to: "Registration" },
  { from: "Registration", to: "First deposit" },
  { from: "Deposit", to: "First trade" },
  { from: "Trade", to: "Active, recurring user" },
];
---

<section class="funnel" id="funnel" aria-labelledby="funnel-heading">
  <div class="container" data-reveal="section">
    <header class="section-header funnel__header">
      <p class="eyebrow eyebrow--dim" data-reveal-item>The revenue funnel</p>
      <h2 id="funnel-heading" class="section-title" data-reveal-item>
        Every step optimized for <span class="gradient-text">exchange economics</span>
      </h2>
      <span class="section-line funnel__line" data-reveal-item></span>
      <p class="lede funnel__intro" data-reveal-item>
        We don't just collect commissions. We help engineer the full journey — from first click to recurring volume — across deals, content, and community strategy.
      </p>
    </header>

    <ol class="funnel__track" role="list">
      {steps.map(({ from, to }, index) => (
        <li class="funnel__step" data-reveal-card>
          <span class="funnel__marker" aria-hidden="true">
            <span class="funnel__marker-dot"></span>
          </span>
          <div class="funnel__card">
            <span class="visually-hidden">Step {index + 1}:</span>
            <p class="funnel__flow">
              <span class="funnel__from">{from}</span>
              <span class="funnel__arrow" aria-hidden="true">→</span>
              <span class="funnel__to">{to}</span>
            </p>
          </div>
        </li>
      ))}
    </ol>
  </div>
</section>

<style>
  .funnel {
    padding-block: 3.5rem;
    border-top: 1px solid var(--border);
    overflow: hidden;
  }

  .funnel__header {
    text-align: center;
  }

  .funnel__line {
    margin-inline: auto;
    transform-origin: center;
  }

  .funnel__intro {
    margin-top: 1.25rem;
    margin-inline: auto;
    text-align: center;
    font-size: clamp(1rem, 2.8vw, 1.125rem);
  }

  .funnel__track {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    list-style: none;
    padding: 0;
    margin: 0;
    position: relative;
  }

  .funnel__track::before {
    content: "";
    position: absolute;
    left: 11px;
    top: 1.25rem;
    bottom: 1.25rem;
    width: 2px;
    background: linear-gradient(
      180deg,
      rgba(228, 198, 90, 0.45) 0%,
      rgba(139, 92, 246, 0.35) 50%,
      rgba(34, 211, 238, 0.3) 100%
    );
    pointer-events: none;
  }

  .funnel__step {
    display: grid;
    grid-template-columns: 24px minmax(0, 1fr);
    gap: 0.875rem;
    align-items: stretch;
    min-width: 0;
  }

  .funnel__marker {
    display: flex;
    align-items: flex-start;
    justify-content: center;
    padding-top: 1.125rem;
    position: relative;
    z-index: 1;
    flex-shrink: 0;
  }

  .funnel__marker-dot {
    width: 10px;
    height: 10px;
    border-radius: 50%;
    background: var(--gold);
    box-shadow: 0 0 0 3px rgba(10, 10, 15, 0.9), 0 0 12px rgba(228, 198, 90, 0.35);
  }

  .funnel__card {
    min-width: 0;
    padding: 1rem 1.125rem;
    background:
      linear-gradient(135deg, rgba(228, 198, 90, 0.05) 0%, transparent 55%),
      rgba(8, 8, 12, 0.72);
    border: 1px solid rgba(255, 255, 255, 0.09);
    border-radius: 10px;
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
  }

  .funnel__flow {
    display: flex;
    flex-wrap: wrap;
    align-items: baseline;
    gap: 0.25rem 0.5rem;
    margin: 0;
    min-width: 0;
  }

  .funnel__from {
    font-size: 0.6875rem;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--text-dim);
    line-height: 1.4;
  }

  .funnel__arrow {
    font-family: var(--font-display);
    font-size: 0.875rem;
    font-weight: 500;
    color: var(--gold);
    opacity: 0.75;
    line-height: 1.4;
    flex-shrink: 0;
  }

  .funnel__to {
    flex: 1 1 100%;
    font-family: var(--font-display);
    font-size: clamp(1.0625rem, 4vw, 1.25rem);
    font-weight: 500;
    letter-spacing: -0.02em;
    line-height: 1.35;
    color: var(--text);
    word-break: break-word;
  }

  .visually-hidden {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }

  @media (max-width: 380px) {
    .funnel__flow {
      flex-direction: column;
      align-items: flex-start;
      gap: 0.125rem;
    }

    .funnel__arrow {
      transform: rotate(90deg);
      margin-block: 0.125rem;
    }

    .funnel__to {
      flex-basis: auto;
    }
  }

  @media (min-width: 640px) {
    .funnel {
      padding-block: 4rem;
    }

    .funnel__to {
      flex: 1 1 auto;
    }
  }

  @media (min-width: 768px) {
    .funnel__header {
      text-align: left;
    }

    .funnel__line {
      margin-inline: 0;
      transform-origin: left center;
    }

    .funnel__intro {
      margin-inline: 0;
      text-align: left;
      font-size: 1.125rem;
    }

    .funnel__track {
      display: grid;
      grid-template-columns: repeat(2, 1fr);
      gap: 1.25rem;
    }

    .funnel__track::before {
      display: none;
    }

    .funnel__step {
      grid-template-columns: 1fr;
      gap: 0;
    }

    .funnel__marker {
      display: none;
    }

    .funnel__card {
      height: 100%;
      padding: 1.5rem 1.75rem;
      position: relative;
      transition: border-color 0.35s, box-shadow 0.35s;
    }

    .funnel__card::before {
      content: "";
      position: absolute;
      left: 0;
      top: 1.25rem;
      bottom: 1.25rem;
      width: 2px;
      background: var(--gradient-wealth);
      opacity: 0.5;
      border-radius: 1px;
    }

    .funnel__card:hover {
      border-color: rgba(228, 198, 90, 0.2);
      box-shadow: 0 16px 48px rgba(0, 0, 0, 0.3);
    }

    .funnel__flow {
      padding-left: 0.75rem;
    }

    .funnel__from {
      font-size: 0.6875rem;
    }

    .funnel__to {
      font-size: clamp(1.125rem, 2vw, 1.375rem);
    }
  }

  @media (min-width: 1024px) {
    .funnel {
      padding-block: 7rem;
    }

    .funnel__card {
      padding: 1.75rem 2rem;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .funnel__card {
      transition: none;
    }
  }
</style>
