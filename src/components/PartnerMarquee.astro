---
import { exchanges } from "../data/exchanges";

const track = [...exchanges, ...exchanges];
---

<div class="marquee" data-reveal="marquee" aria-label="Exchange partners">
  <div class="marquee__fade marquee__fade--left" aria-hidden="true"></div>
  <div class="marquee__fade marquee__fade--right" aria-hidden="true"></div>
  <div class="marquee__track">
    {track.map(({ name, accent }) => (
      <span class="marquee__item" style={`--accent: ${accent}`}>{name}</span>
    ))}
  </div>
</div>

<style>
  .marquee {
    position: relative;
    overflow: hidden;
    margin-top: 1rem;
    padding-block: 0.5rem;
    mask-image: linear-gradient(90deg, transparent, black 12%, black 88%, transparent);
    -webkit-mask-image: linear-gradient(90deg, transparent, black 12%, black 88%, transparent);
  }

  .marquee__fade {
    position: absolute;
    top: 0;
    bottom: 0;
    width: clamp(2rem, 8vw, 4rem);
    z-index: 1;
    pointer-events: none;
  }

  .marquee__fade--left {
    left: 0;
    background: linear-gradient(90deg, rgba(5, 5, 8, 0.85), transparent);
  }

  .marquee__fade--right {
    right: 0;
    background: linear-gradient(270deg, rgba(5, 5, 8, 0.85), transparent);
  }

  .marquee__track {
    display: flex;
    width: max-content;
    gap: clamp(1.5rem, 5vw, 3rem);
    animation: marquee 32s linear infinite;
  }

  .marquee__item {
    flex-shrink: 0;
    font-family: var(--font-display);
    font-size: clamp(1.125rem, 2.5vw, 1.5rem);
    font-weight: 600;
    letter-spacing: -0.03em;
    color: rgba(232, 232, 240, 0.35);
    transition: color 0.3s;
    white-space: nowrap;
  }

  .marquee__item:hover {
    color: var(--accent);
  }

  @keyframes marquee {
    from { transform: translateX(0); }
    to { transform: translateX(-50%); }
  }

  @media (prefers-reduced-motion: reduce) {
    .marquee__track {
      animation: none;
      flex-wrap: wrap;
      justify-content: center;
      width: 100%;
      gap: 1rem 2rem;
    }

    .marquee {
      mask-image: none;
      -webkit-mask-image: none;
    }

    .marquee__fade {
      display: none;
    }
  }
</style>
