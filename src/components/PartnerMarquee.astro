---
import { exchanges } from "../data/exchanges";

const track = [...exchanges, ...exchanges];
---

<div class="marquee" data-reveal="marquee" aria-label="Exchange partners">
  <div class="marquee__fade marquee__fade--left" aria-hidden="true"></div>
  <div class="marquee__fade marquee__fade--right" aria-hidden="true"></div>
  <div class="marquee__track">
    {track.map(({ name, slug, logo, accent }) => (
      <span class="marquee__item" style={`--accent: ${accent}`}>
        <span class="marquee__logo-slot">
          <img
            class="marquee__logo"
            src={logo}
            alt={name}
            width="120"
            height="36"
            loading="lazy"
            decoding="async"
            data-fallback={slug}
          />
          <span class="marquee__fallback" hidden>{name}</span>
        </span>
      </span>
    ))}
  </div>
</div>

<script>
  document.querySelectorAll<HTMLImageElement>(".marquee__logo").forEach((img) => {
    const slot = img.closest(".marquee__logo-slot");
    const fallback = slot?.querySelector<HTMLElement>(".marquee__fallback");

    img.addEventListener("error", () => {
      img.hidden = true;
      if (fallback) fallback.hidden = false;
    });

    if (!img.complete || img.naturalWidth === 0) {
      img.addEventListener("load", () => {
        if (img.naturalWidth === 0 && fallback) {
          img.hidden = true;
          fallback.hidden = false;
        }
      });
    }
  });
</script>

<style>
  .marquee {
    position: relative;
    overflow: hidden;
    margin-top: 1rem;
    padding-block: 0.5rem;
    mask-image: linear-gradient(90deg, transparent, black 12%, black 88%, transparent);
    -webkit-mask-image: linear-gradient(90deg, transparent, black 12%, black 88%, transparent);
  }

  .marquee__fade {
    position: absolute;
    top: 0;
    bottom: 0;
    width: clamp(2rem, 8vw, 4rem);
    z-index: 1;
    pointer-events: none;
  }

  .marquee__fade--left {
    left: 0;
    background: linear-gradient(90deg, rgba(5, 5, 8, 0.85), transparent);
  }

  .marquee__fade--right {
    right: 0;
    background: linear-gradient(270deg, rgba(5, 5, 8, 0.85), transparent);
  }

  .marquee__track {
    display: flex;
    width: max-content;
    gap: clamp(1.5rem, 5vw, 3rem);
    animation: marquee 32s linear infinite;
  }

  .marquee__item {
    flex-shrink: 0;
    display: flex;
    align-items: center;
  }

  .marquee__logo-slot {
    display: flex;
    align-items: center;
    justify-content: center;
    min-width: 6.5rem;
    height: 2.5rem;
    padding-inline: 0.75rem;
    background: rgba(255, 255, 255, 0.03);
    border: 1px dashed rgba(255, 255, 255, 0.12);
    border-radius: 8px;
  }

  .marquee__logo {
    max-width: 6rem;
    max-height: 1.75rem;
    width: auto;
    height: auto;
    object-fit: contain;
    opacity: 0.88;
    filter: grayscale(0.15);
  }

  .marquee__fallback {
    font-family: var(--font-display);
    font-size: 0.8125rem;
    font-weight: 600;
    letter-spacing: -0.02em;
    color: rgba(232, 232, 240, 0.45);
    white-space: nowrap;
  }

  .marquee__item:hover .marquee__logo {
    opacity: 1;
    filter: none;
  }

  .marquee__item:hover .marquee__fallback {
    color: var(--accent);
  }

  @keyframes marquee {
    from { transform: translateX(0); }
    to { transform: translateX(-50%); }
  }

  @media (prefers-reduced-motion: reduce) {
    .marquee__track {
      animation: none;
      flex-wrap: wrap;
      justify-content: center;
      width: 100%;
      gap: 1rem 1.25rem;
    }

    .marquee {
      mask-image: none;
      -webkit-mask-image: none;
    }

    .marquee__fade {
      display: none;
    }
  }
</style>
