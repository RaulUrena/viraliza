---
---

<div class="site-bg" aria-hidden="true">
  <video
    class="site-bg__video"
    autoplay
    muted
    loop
    playsinline
    preload="auto"
  >
    <source src="/bg.mp4" type="video/mp4" />
  </video>
  <div class="site-bg__scrim"></div>
</div>

<style is:global>
  .site-bg {
    position: fixed;
    inset: 0;
    z-index: 0;
    pointer-events: none;
    overflow: hidden;
    background: #050508;
  }

  .site-bg__video {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: 60% center;
    opacity: 0.52;
    transform: scale(1.2);
    filter: blur(52px) brightness(0.62) saturate(1.5) contrast(1.08);
  }

  .site-bg__scrim {
    position: absolute;
    inset: 0;
    background:
      linear-gradient(180deg, rgba(3, 3, 5, 0.55) 0%, rgba(3, 3, 5, 0.22) 45%, rgba(3, 3, 5, 0.6) 100%),
      radial-gradient(ellipse 80% 60% at 50% 20%, rgba(228, 198, 90, 0.06) 0%, transparent 50%),
      radial-gradient(ellipse 90% 70% at 55% 35%, rgba(139, 92, 246, 0.1) 0%, transparent 60%);
  }

  @media (prefers-reduced-motion: reduce) {
    .site-bg__video {
      display: none;
    }
  }
</style>

<script>
  const video = document.querySelector<HTMLVideoElement>(".site-bg__video");
  if (video && !window.matchMedia("(prefers-reduced-motion: reduce)").matches) {
    video.muted = true;
    video.play().catch(() => {});
  }
</script>
