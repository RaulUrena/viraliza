---
---

<div class="site-bg" aria-hidden="true">
  <img class="site-bg__poster" src="/bg-poster.jpg" alt="" width="1920" height="1080" decoding="async" fetchpriority="high" />
  <video
    class="site-bg__video"
    autoplay
    muted
    loop
    playsinline
    preload="metadata"
    poster="/bg-poster.jpg"
  >
    <source src="/bg.mp4" type="video/mp4" />
  </video>
  <div class="site-bg__scrim"></div>
</div>

<style is:global>
  .site-bg {
    position: fixed;
    inset: 0;
    z-index: 0;
    pointer-events: none;
    overflow: hidden;
    background: #0a0a0f;
  }

  .site-bg__poster,
  .site-bg__video {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: 60% center;
  }

  .site-bg__poster {
    z-index: 0;
  }

  .site-bg__video {
    z-index: 1;
    opacity: 0.52;
    transform: scale(1.2);
    filter: blur(52px) brightness(0.62) saturate(1.5) contrast(1.08);
    will-change: transform;
  }

  .site-bg__scrim {
    position: absolute;
    inset: 0;
    z-index: 2;
    background:
      linear-gradient(180deg, rgba(10, 10, 15, 0.55) 0%, rgba(10, 10, 15, 0.68) 45%, rgba(10, 10, 15, 0.78) 100%),
      radial-gradient(ellipse 85% 70% at 50% 35%, transparent 25%, rgba(10, 10, 15, 0.45) 100%);
  }

  @media (max-width: 767px) {
    .site-bg__video {
      opacity: 0.42;
      transform: scale(1.1);
      filter: blur(36px) brightness(0.58) saturate(1.35) contrast(1.05);
    }

    .site-bg__scrim {
      background:
        linear-gradient(180deg, rgba(10, 10, 15, 0.62) 0%, rgba(10, 10, 15, 0.74) 50%, rgba(10, 10, 15, 0.82) 100%),
        radial-gradient(ellipse 90% 75% at 50% 30%, transparent 15%, rgba(10, 10, 15, 0.5) 100%);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .site-bg__video {
      display: none;
    }

    .site-bg__poster {
      display: block;
    }
  }
</style>

<script>
  const video = document.querySelector<HTMLVideoElement>(".site-bg__video");
  const motionQuery = window.matchMedia("(prefers-reduced-motion: reduce)");

  function syncVideo(): void {
    if (!video) return;

    if (motionQuery.matches) {
      video.pause();
      video.removeAttribute("src");
      video.load();
      return;
    }

    video.muted = true;
    video.play().catch(() => {});
  }

  syncVideo();
  motionQuery.addEventListener("change", syncVideo);
</script>
