---
import type { ExchangeId } from "../../data/exchanges";

interface Props {
  id: ExchangeId;
  name: string;
  logo: string;
  wide?: boolean;
}

const { name, logo, wide = false } = Astro.props;
---

<div class:list={["exchange", wide && "exchange--wide"]}>
  <div class="exchange__badge">
    <img
      src={logo}
      alt=""
      width="64"
      height="64"
      class="exchange__img"
      loading="lazy"
      decoding="async"
    />
  </div>
  <span class="exchange__name">{name}</span>
</div>

<style>
  .exchange {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 0.75rem;
    width: 100%;
  }

  .exchange__badge {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 3.75rem;
    height: 3.75rem;
    border-radius: 50%;
    overflow: hidden;
    background: rgba(255, 255, 255, 0.03);
    border: 1px solid rgba(255, 255, 255, 0.08);
    box-shadow: 0 4px 20px rgba(0, 0, 0, 0.25);
    transition: transform 0.25s, box-shadow 0.25s, border-color 0.25s;
  }

  .exchange__img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .exchange--wide .exchange__badge {
    width: 4.5rem;
    height: 4.5rem;
    border-radius: 14px;
    background: #0a0a0f;
    padding: 0.375rem;
  }

  .exchange--wide .exchange__img {
    object-fit: contain;
    border-radius: 8px;
  }

  .exchange__name {
    font-family: var(--font-body);
    font-size: 0.8125rem;
    font-weight: 500;
    color: var(--text-dim);
    letter-spacing: 0.01em;
    text-align: center;
  }

  :global(.partner-tile:hover) .exchange__badge {
    transform: translateY(-2px);
    border-color: rgba(255, 255, 255, 0.14);
    box-shadow: 0 8px 28px rgba(0, 0, 0, 0.35);
  }

  @media (prefers-reduced-motion: reduce) {
    :global(.partner-tile:hover) .exchange__badge {
      transform: none;
    }
  }
</style>
