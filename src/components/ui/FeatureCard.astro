---
interface Props {
  title: string;
  desc?: string;
  variant?: "default" | "accent" | "flow";
  href?: string;
  external?: boolean;
}

const { title, desc, variant = "default", href, external = false } = Astro.props;

const Tag = href ? "a" : "div";
const className = `feature-card feature-card--${variant}`;
const linkProps = href
  ? {
      href,
      ...(external ? { target: "_blank", rel: "noopener noreferrer" } : {}),
    }
  : {};
---

<li class="feature-card-wrap" data-reveal-card>
  <Tag
    class={className}
    data-interactive-card
    {...linkProps}
  >
    <div class="feature-card__sheen" aria-hidden="true"></div>
    <div class="feature-card__surface">
      {variant === "flow" ? (
        <span class="feature-card__flow-label">{title}</span>
      ) : (
        <>
          <h3 class="feature-card__title">{title}</h3>
          {desc && <p class="feature-card__desc">{desc}</p>}
          <slot />
        </>
      )}
    </div>
  </Tag>
</li>

<style is:global>
  .feature-card-wrap {
    list-style: none;
    height: 100%;
  }

  .feature-card {
    position: relative;
    display: block;
    height: 100%;
    text-decoration: none;
    color: inherit;
    transform-style: preserve-3d;
    transform-origin: center center;
  }

  .feature-card__sheen {
    position: absolute;
    inset: 0;
    z-index: 0;
    background: radial-gradient(
      480px circle at var(--mouse-x, 25%) var(--mouse-y, 15%),
      rgba(228, 198, 90, 0.12),
      transparent 50%
    );
    opacity: 0;
    transition: opacity 0.5s ease;
    pointer-events: none;
  }

  .feature-card:hover .feature-card__sheen,
  .feature-card:focus-visible .feature-card__sheen {
    opacity: 1;
  }

  .feature-card__surface {
    position: relative;
    z-index: 1;
    height: 100%;
    padding: 2rem 1.875rem 1.875rem;
    background: var(--gradient-surface), rgba(8, 8, 12, 0.65);
    backdrop-filter: blur(28px);
    -webkit-backdrop-filter: blur(28px);
    border: 1px solid rgba(255, 255, 255, 0.08);
    border-radius: 12px;
    transition:
      background 0.45s ease,
      box-shadow 0.45s ease,
      border-color 0.45s ease;
  }

  .feature-card__surface::before {
    content: "";
    position: absolute;
    top: 0;
    left: 2rem;
    right: 2rem;
    height: 1px;
    background: linear-gradient(90deg, transparent, rgba(228, 198, 90, 0.4), transparent);
    opacity: 0.6;
    transition: opacity 0.45s ease;
  }

  .feature-card__surface::after {
    content: "";
    position: absolute;
    left: 0;
    top: 2rem;
    bottom: 2rem;
    width: 2px;
    background: var(--gradient-wealth);
    opacity: 0.35;
    border-radius: 1px;
    transition: opacity 0.45s ease;
  }

  .feature-card:hover .feature-card__surface,
  .feature-card:focus-visible .feature-card__surface {
    background:
      linear-gradient(165deg, rgba(228, 198, 90, 0.08) 0%, rgba(139, 92, 246, 0.06) 40%, transparent 70%),
      rgba(10, 10, 16, 0.78);
    border-color: rgba(228, 198, 90, 0.18);
    box-shadow:
      0 24px 60px rgba(0, 0, 0, 0.35),
      0 0 40px rgba(228, 198, 90, 0.04),
      inset 0 1px 0 rgba(255, 255, 255, 0.05);
  }

  .feature-card:hover .feature-card__surface::before,
  .feature-card:focus-visible .feature-card__surface::before {
    opacity: 1;
  }

  .feature-card:hover .feature-card__surface::after,
  .feature-card:focus-visible .feature-card__surface::after {
    opacity: 0.9;
  }

  .feature-card--accent .feature-card__surface {
    background:
      linear-gradient(145deg, rgba(228, 198, 90, 0.1) 0%, rgba(139, 92, 246, 0.08) 45%, transparent 75%),
      rgba(8, 8, 14, 0.72);
    border-color: rgba(228, 198, 90, 0.15);
  }

  .feature-card--accent .feature-card__title {
    background: var(--gradient-wealth);
    -webkit-background-clip: text;
    background-clip: text;
    -webkit-text-fill-color: transparent;
  }

  .feature-card--flow .feature-card__surface {
    display: flex;
    align-items: center;
    min-height: 4.5rem;
    padding-block: 1.5rem;
  }

  .feature-card__title {
    font-family: var(--font-display);
    font-size: 1.125rem;
    font-weight: 600;
    letter-spacing: -0.025em;
    line-height: 1.25;
    margin-bottom: 0.625rem;
    padding-right: 0.75rem;
  }

  .feature-card__desc {
    font-size: 0.9375rem;
    color: var(--text-dim);
    line-height: 1.7;
  }

  .feature-card__flow-label {
    font-family: var(--font-display);
    font-size: clamp(1.0625rem, 2.5vw, 1.3125rem);
    font-weight: 500;
    letter-spacing: -0.02em;
    line-height: 1.35;
  }
</style>
